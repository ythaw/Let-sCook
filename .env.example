# Copy to ".env" in this folder (never commit .env).
# Restart "npx expo start" after changing env vars.

# Google AI Studio → Get API key → paste here (either name works):
EXPO_PUBLIC_GEMINI_API_KEY=
# EXPO_PUBLIC_GOOGLE_AI_API_KEY=

# Model id (see AI Studio list). Default below is fast and widely available.
EXPO_PUBLIC_GEMINI_MODEL=gemini-2.0-flash

# Optional: only if Google gives you a different API base.
# EXPO_PUBLIC_GEMINI_API_BASE=
